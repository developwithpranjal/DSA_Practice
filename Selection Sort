#include<iostream>
using namespace std;
int main(){
    int n;
    cout<<"Enter the length of Array :";
    cin>>n;
    int arr[100];
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    for (int i=0;i<n;i++){
        int min_ele_index=i;
        for(int j=i+1;j<n;j++){
            if(arr[j]<arr[min_ele_index]){
                min_ele_index=j;
            }
            
        }
        swap(arr[i],arr[min_ele_index]);
    }
    for(int i=0;i<n;i++){
cout<<arr[i]<<" ";
    }

}
