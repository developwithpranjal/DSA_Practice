// MULTIPLE INHERITANCE :

#include <iostream>
using namespace std;

class Human
{
protected:
    string name;
};
class Person
{
protected:
    int age;
};
class Student : public Human,public Person
{
    
    string gender;

    public:
    Student(string n, int a, string g)
    {
        name = n;
        age = a;
        gender=g;
    }

    void display()
    {
        cout << name << " " << age << " " << gender << endl;
    }
};

int main()
{
    Student obj("Pranjal", 21, "Male");
    obj.display();
    return 0;
}
