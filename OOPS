// HIERARCHICAL INHERITANCE :

#include<iostream>
using namespace std;

class Human
{
protected:
    string name;
    int age;
};

class Student : public Human
{
    int roll_no;

public:

    Student(string n, int a, int r)
    {
        name = n;
        age = a;
        roll_no = r;
    }

    void displayStudent()
    {
        cout << "Student : " << name << " "
             << age << " "
             << roll_no << endl;
    }
};

class Teacher : public Human
{
    string subject;

public:

    Teacher(string n, int a, string s)
    {
        name = n;
        age = a;
        subject = s;
    }

    void displayTeacher()
    {
        cout << "Teacher : " << name << " "
             << age << " "
             << subject << endl;
    }
};

int main()
{

    Student s("Pranjal", 21, 101);
    s.displayStudent();

    Teacher t("Rahul", 40, "Maths");
    t.displayTeacher();

    return 0;
}

